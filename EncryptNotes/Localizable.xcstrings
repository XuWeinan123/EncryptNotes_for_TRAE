    "# Markdown Preview\n\n- **Bold** and *italic*\n- `inline code`\n\n> This is the actual Markdown rendering component." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Markdown Vorschau\n\n- **Fett** und *kursiv*\n- `inline code`\n\n> Dies ist die tatsächliche Markdown-Rendering-Komponente."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Markdown Preview\n\n- **Bold** and *italic*\n- `inline code`\n\n> This is the actual Markdown rendering component."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Vista previa de Markdown\n\n- **Negrita** y *cursiva*\n- `código en línea`\n\n> Este es el componente de renderizado de Markdown real."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Aperçu Markdown\n\n- **Gras** et *italique*\n- `code en ligne`\n\n> Ceci est le composant de rendu Markdown réel."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Markdown プレビュー\n\n- **太字** と *斜体*\n- `インラインコード`\n\n> これが実際の Markdown レンダリングコンポーネントです。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Markdown 미리보기\n\n- **굵게**와 *기울임꼴*\n- `인라인 코드`\n\n> 이것은 실제 Markdown 렌더링 구성 요소입니다."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Pré-visualização de Markdown\n\n- **Negrito** e *itálico*\n- `inline code`\n\n> Este é o componente real de renderização de Markdown."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Markdown 预览\n\n- **粗体** 与 *斜体*\n- `inline code`\n\n> 这是实际的 Markdown 渲染组件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "# Markdown 預覽\n\n- **粗體** 與 *斜體*\n- `行內程式碼`\n\n> 這是實際的 Markdown 呈現元件。"
          }
        }
